# MongoDB Configuration
MONGODB_URI=mongodb://127.0.0.1:27017/Placement-Portal

# JWT Configuration
# Generate secure secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_secure_random_32_byte_hex_string_here

# Server Configuration
PORT=5001
NODE_ENV=development

# Frontend Origin (CORS)
CLIENT_ORIGIN=http://localhost:5173

# Email Service Configuration (Gmail OTP)
OTP_EMAIL_SERVICE=gmail
OTP_EMAIL_USER=your-email@gmail.com
OTP_EMAIL_PASS=your-app-specific-password

# Frontend Configuration
VITE_API_URL=http://localhost:5001/api
VITE_SOCKET_URL=http://localhost:5001
